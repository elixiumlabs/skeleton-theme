<section class="customer-order">
  <div class="customer-order__header">
    <p class="eyebrow">Order</p>
    <h1>{{ order.name }}</h1>
    <p>{{ order.created_at | date: format: 'abbreviated_date' }}</p>
  </div>

  <div class="customer-order__items">
    {% for line_item in order.line_items %}
      <article class="customer-order__item">
        <div>
          <h2>{{ line_item.title }}</h2>
          {% if line_item.selling_plan_allocation %}
            <p>{{ line_item.selling_plan_allocation.selling_plan.name }}</p>
          {% endif %}
          {% if line_item.unit_price_measurement %}
            <span class="unit-price">
              {{ line_item.unit_price | money }}
              <span aria-hidden="true">/</span>
              {% if line_item.unit_price_measurement.reference_value != 1 %}
                {{ line_item.unit_price_measurement.reference_value }}
              {% endif %}
              {{ line_item.unit_price_measurement.reference_unit }}
            </span>
          {% endif %}
          {% if line_item.line_level_discount_allocations.size > 0 %}
            <ul>
              {% for discount in line_item.line_level_discount_allocations %}
                <li>{{ discount.discount_application.title }} (-{{ discount.amount | money }})</li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
        <p>Qty {{ line_item.quantity }}</p>
        <p class="price">
          {% if line_item.original_line_price != line_item.final_line_price %}
            <s>{{ line_item.original_line_price | money }}</s>
          {% endif %}
          {{ line_item.final_line_price | money }}
        </p>
      </article>
    {% endfor %}
  </div>

  <aside class="customer-order__summary">
    <p><span>Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></p>
    {% for discount in order.cart_level_discount_applications %}
      <p><span>{{ discount.title }}</span><span>-{{ discount.total_allocated_amount | money }}</span></p>
    {% endfor %}
    <p><span>Shipping</span><span>{{ order.shipping_price | money }}</span></p>
    <p><span>Tax</span><span>{{ order.tax_price | money }}</span></p>
    <strong><span>Total</span><span>{{ order.total_price | money }}</span></strong>
  </aside>
</section>

{% style %}
  .customer-order {
    display: grid;
    gap: 2rem;
    padding-block: 3rem 4rem;
  }

  .customer-order__header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }

  .customer-order h1 {
    font-size: clamp(2.4rem, 5vw, 5rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .customer-order__items {
    display: grid;
    gap: 1px;
  }

  .customer-order__item {
    align-items: start;
    border: 1px solid var(--color-border);
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1fr) auto auto;
    padding: 1rem;
  }

  .customer-order__item h2 {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .customer-order__item p,
  .customer-order__item li {
    color: var(--color-muted);
  }

  .customer-order__item ul {
    color: var(--color-accent);
    list-style: none;
    margin-top: 0.5rem;
    padding: 0;
  }

  .customer-order__summary {
    background: var(--color-foreground);
    color: #ffffff;
    display: grid;
    gap: 0.75rem;
    justify-self: end;
    min-width: min(24rem, 100%);
    padding: 1.25rem;
  }

  .customer-order__summary p,
  .customer-order__summary strong {
    display: flex;
    justify-content: space-between;
  }

  @media (max-width: 700px) {
    .customer-order__item {
      grid-template-columns: 1fr;
    }

    .customer-order__summary {
      justify-self: stretch;
    }
  }
{% endstyle %}
