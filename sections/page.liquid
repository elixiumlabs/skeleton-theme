{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

<section class="page-content">
  <p class="eyebrow">{{ section.settings.eyebrow }}</p>
  <h1>{{ page.title }}</h1>

  <div class="page-content__body">
    {{ page.content }}
  </div>
</section>

{% stylesheet %}
  .page-content {
    padding-block: 3rem 4rem;
  }

  .page-content h1 {
    border-bottom: 1px solid var(--color-border);
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    padding-bottom: 2rem;
    text-transform: uppercase;
  }

  .page-content__body {
    color: var(--color-muted);
    font-size: 1.02rem;
    margin-top: 2rem;
    max-width: 48rem;
  }

  .page-content__body > * + * {
    margin-top: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Studio notes"
    }
  ]
}
{% endschema %}
