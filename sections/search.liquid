{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<section class="search-page">
  <div class="search-page__header">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ 'search.title' | t }}</h1>
  </div>

  <form class="search-page__form" action="{{ routes.search_url }}" method="get" role="search">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      predictive-search="true"
    >
    <input type="hidden" name="type" value="product,article,page">
    <input type="hidden" name="options[prefix]" value="last">
    <button type="submit">{{ 'search.submit' | t }}</button>
  </form>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <p class="search-page__status">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
    {% else %}
      <p class="search-page__status">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

      <form class="search-page__filters" method="get">
        <input type="hidden" name="q" value="{{ search.terms | escape }}">
        <input type="hidden" name="type" value="product,article,page">
        <input type="hidden" name="options[prefix]" value="last">
        {% for filter in search.filters %}
          <details class="search-filter">
            <summary>{{ filter.label }}</summary>
            <div class="search-filter__values">
              {% case filter.type %}
                {% when 'price_range' %}
                  <label>
                    <span>Min</span>
                    <input name="{{ filter.min_value.param_name }}" type="number" min="0" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                  </label>
                  <label>
                    <span>Max</span>
                    <input name="{{ filter.max_value.param_name }}" type="number" min="0" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
                  </label>
                {% else %}
                  {% for value in filter.values %}
                    <label class="search-filter__choice">
                      <input
                        type="checkbox"
                        name="{{ value.param_name }}"
                        value="{{ value.value }}"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                      >
                      <span>{{ value.label }} ({{ value.count }})</span>
                    </label>
                  {% endfor %}
              {% endcase %}
            </div>
          </details>
        {% endfor %}
        {% if search.filters.size > 0 %}
          <button type="submit">Apply filters</button>
        {% endif %}
      </form>

      <div class="search-results product-grid">
        {% paginate search.results by 20 %}
          {% for result in search.results %}
            {% if result.object_type == 'product' %}
              {% render 'product-card', product: result %}
            {% else %}
              <article class="search-result">
                {% assign featured_image = result.featured_image | default: result.image %}
                {% if featured_image %}
                  {% render 'image', class: 'search-result__image', image: featured_image, url: result.url, width: 500 %}
                {% endif %}
                <div class="search-result__content">
                  <p>{{ result.object_type | capitalize }}</p>
                  <h2>{{ result.title | link_to: result.url }}</h2>
                </div>
              </article>
            {% endif %}
          {% endfor %}

          {{ paginate | default_pagination }}
        {% endpaginate %}
      </div>
    {% endif %}
  {% endif %}
</section>

{% stylesheet %}
  .search-page {
    padding-block: 3rem 4rem;
  }

  .search-page__header {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    padding-bottom: 2rem;
  }

  .search-page h1 {
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .search-page__form {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 46rem;
  }

  .search-page__status {
    color: var(--color-muted);
    margin-block: 1.5rem;
  }

  .search-page__filters {
    align-items: start;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-block: 1.5rem;
  }

  .search-filter {
    position: relative;
  }

  .search-filter summary {
    border: 1px solid var(--color-border);
    cursor: pointer;
    display: inline-flex;
    font-family: var(--font-secondary--family);
    font-size: 0.78rem;
    font-weight: 700;
    list-style: none;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    text-transform: uppercase;
  }

  .search-filter summary::-webkit-details-marker {
    display: none;
  }

  .search-filter__values {
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: 0 1.25rem 3rem rgba(8, 6, 7, 0.14);
    display: grid;
    gap: 0.7rem;
    left: 0;
    min-width: 16rem;
    padding: 1rem;
    position: absolute;
    top: calc(100% + 0.4rem);
    z-index: 6;
  }

  .search-filter__choice {
    align-items: center;
    display: flex;
    gap: 0.55rem;
    min-width: max-content;
  }

  .search-results {
    margin-top: 2rem;
  }

  .search-result {
    border: 1px solid var(--color-border);
    display: grid;
  }

  .search-result__image {
    aspect-ratio: 4 / 5;
    object-fit: cover;
    width: 100%;
  }

  .search-result__content {
    padding: 1rem;
  }

  .search-result__content a {
    font-family: var(--font-secondary--family);
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
  }

  .search-result__content .price {
    color: var(--color-accent);
    display: block;
    margin-top: 0.45rem;
  }

  .search-results .prev,
  .search-results .page,
  .search-results .next {
    grid-column: 1 / -1;
  }

  @media (max-width: 700px) {
    .search-filter,
    .search-filter summary,
    .search-page__filters button {
      width: 100%;
    }

    .search-filter__values {
      position: static;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Find your finish"
    }
  ]
}
{% endschema %}
