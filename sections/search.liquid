{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<section class="search-page">
  <div class="search-page__header">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ 'search.title' | t }}</h1>
  </div>

  <form class="search-page__form" action="{{ routes.search_url }}" method="get" role="search">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      predictive-search="true"
    >
    <input type="hidden" name="type" value="product,article,page">
    <input type="hidden" name="options[prefix]" value="last">
    <button type="submit">{{ 'search.submit' | t }}</button>
  </form>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <p class="search-page__status">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
    {% else %}
      <p class="search-page__status">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

      <div class="search-results product-grid">
        {% paginate search.results by 20 %}
          {% for result in search.results %}
            {% if result.object_type == 'product' %}
              {% render 'product-card', product: result %}
            {% else %}
              <article class="search-result">
                {% assign featured_image = result.featured_image | default: result.image %}
                {% if featured_image %}
                  {% render 'image', class: 'search-result__image', image: featured_image, url: result.url, width: 500 %}
                {% endif %}
                <div class="search-result__content">
                  <p>{{ result.object_type | capitalize }}</p>
                  <h2>{{ result.title | link_to: result.url }}</h2>
                </div>
              </article>
            {% endif %}
          {% endfor %}

          {{ paginate | default_pagination }}
        {% endpaginate %}
      </div>
    {% endif %}
  {% endif %}
</section>

{% stylesheet %}
  .search-page {
    padding-block: 3rem 4rem;
  }

  .search-page__header {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    padding-bottom: 2rem;
  }

  .search-page h1 {
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .search-page__form {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(0, 1fr) auto;
    max-width: 46rem;
  }

  .search-page__status {
    color: var(--color-muted);
    margin-block: 1.5rem;
  }

  .search-results {
    margin-top: 2rem;
  }

  .search-result {
    border: 1px solid var(--color-border);
    display: grid;
  }

  .search-result__image {
    aspect-ratio: 4 / 5;
    object-fit: cover;
    width: 100%;
  }

  .search-result__content {
    padding: 1rem;
  }

  .search-result__content a {
    font-family: var(--font-secondary--family);
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
  }

  .search-result__content .price {
    color: var(--color-accent);
    display: block;
    margin-top: 0.45rem;
  }

  .search-results .prev,
  .search-results .page,
  .search-results .next {
    grid-column: 1 / -1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Find your finish"
    }
  ]
}
{% endschema %}
