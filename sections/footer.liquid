<footer class="site-footer full-width">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="{{ routes.root_url }}">{{ section.settings.brand_text | default: shop.name }}</a>
      <p>{{ section.settings.tagline }}</p>
    </div>

    <div class="site-footer__links">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </div>

    <div class="site-footer__newsletter">
      <p class="eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
      <h2>{{ section.settings.newsletter_heading }}</h2>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label for="NewsletterEmail-{{ section.id }}" class="visually-hidden">Email address</label>
        <input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Your email address" required>
        <button type="submit">Join</button>
      {% endform %}
    </div>

    <div class="site-footer__markets">
      {% if localization.available_countries.size > 1 %}
        {% form 'localization', class: 'site-footer__localization' %}
          <label for="FooterCountry-{{ section.id }}">Country/region</label>
          <select id="FooterCountry-{{ section.id }}" name="country_code" onchange="this.form.submit()">
            {% for country in localization.available_countries %}
              <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
            {% endfor %}
          </select>
        {% endform %}
      {% endif %}

      {% if localization.available_languages.size > 1 %}
        {% form 'localization', class: 'site-footer__localization' %}
          <label for="FooterLanguage-{{ section.id }}">Language</label>
          <select id="FooterLanguage-{{ section.id }}" name="locale_code" onchange="this.form.submit()">
            {% for language in localization.available_languages %}
              <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                {{ language.endonym_name | capitalize }}
              </option>
            {% endfor %}
          </select>
        {% endform %}
      {% endif %}
    </div>

    <div class="site-footer__shop-follow">
      {{ shop | login_button: action: 'follow' }}
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__payment">
        {% if section.settings.show_payment_icons %}
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        {% endif %}
      </div>
      <div class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: #0A0A0A;
    color: #ffffff;
    display: grid;
    grid-template-columns: var(--content-grid);
    margin-top: 6rem;
    padding: 5rem 0 0;
  }

  .site-footer__inner {
    align-items: start;
    display: grid;
    gap: 2.5rem;
    grid-column: 2;
    grid-template-columns: minmax(14rem, 1fr) minmax(12rem, auto) minmax(18rem, 0.85fr);
  }

  .site-footer a {
    color: currentcolor;
    text-decoration: none;
  }

  /* Brand — bold Poppins in baby pink */
  .site-footer__brand a {
    color: var(--color-accent);
    display: block;
    font-family: var(--font-secondary--family);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1;
    text-transform: uppercase;
    transition: opacity 200ms ease;
  }

  .site-footer__brand a:hover {
    opacity: 0.8;
  }

  .site-footer__brand p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.86rem;
    letter-spacing: 0.02em;
    line-height: 1.7;
    margin-top: 1.1rem;
    max-width: 25rem;
  }

  /* Nav links */
  .site-footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .site-footer__links a {
    color: rgba(255, 255, 255, 0.65);
    font-family: var(--font-secondary--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 0.2rem 0;
    position: relative;
    text-transform: uppercase;
    transition: color 200ms ease;
    width: fit-content;
  }

  .site-footer__links a::after {
    background: var(--color-accent);
    bottom: 0;
    content: '';
    height: 1px;
    left: 0;
    position: absolute;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 260ms ease;
    width: 100%;
  }

  .site-footer__links a:hover {
    color: #ffffff;
  }

  .site-footer__links a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Newsletter */
  .site-footer__newsletter {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(247, 168, 196, 0.25);
    display: grid;
    gap: 1rem;
    padding: 1.75rem;
  }

  .site-footer__newsletter h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    letter-spacing: 0.02em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .site-footer__newsletter form {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .site-footer__newsletter input[type='email'] {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .site-footer__newsletter input[type='email']::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .site-footer__newsletter button {
    letter-spacing: 0.16em;
  }

  /* Markets */
  .site-footer__markets {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    grid-column: 1 / -1;
  }

  .site-footer__shop-follow {
    grid-column: 1 / -1;
  }

  .site-footer__localization {
    display: grid;
    gap: 0.4rem;
  }

  .site-footer__localization label {
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-secondary--family);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .site-footer__localization select {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.84rem;
  }

  /* Bottom bar */
  .site-footer__bottom {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    grid-column: 1 / -1;
    justify-content: space-between;
    margin-top: 1rem;
    padding-block: 1.5rem;
  }

  .site-footer__payment {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .site-footer__payment svg {
    width: 2.1rem;
  }

  .site-footer__copyright {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "Lash Candii"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Glossy, flirty lashes for beauty lovers who like their soft glam expensive."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "newsletter_eyebrow",
      "label": "Newsletter eyebrow",
      "default": "The list"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Pink-room drops and private lash rituals"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
