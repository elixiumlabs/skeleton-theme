<footer class="site-footer full-width">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="{{ routes.root_url }}">{{ section.settings.brand_text | default: shop.name }}</a>
      <p>{{ section.settings.tagline }}</p>
    </div>

    <div class="site-footer__links">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </div>

    <div class="site-footer__payment">
      {% if section.settings.show_payment_icons %}
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      {% endif %}
    </div>

    <div class="site-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
    </div>
  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: #080607;
    color: #ffffff;
    display: grid;
    grid-template-columns: var(--content-grid);
    margin-top: 5rem;
    padding: 3rem 0;
  }

  .site-footer__inner {
    align-items: start;
    display: grid;
    gap: 2rem;
    grid-column: 2;
    grid-template-columns: minmax(14rem, 1fr) auto minmax(10rem, auto);
  }

  .site-footer a {
    color: currentcolor;
    text-decoration: none;
  }

  .site-footer__brand a {
    color: var(--color-accent);
    font-family: var(--font-secondary--family);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .site-footer__brand p,
  .site-footer__copyright {
    color: color-mix(in srgb, #ffffff 70%, transparent);
    font-size: 0.9rem;
    margin-top: 0.85rem;
    max-width: 28rem;
  }

  .site-footer__links,
  .site-footer__payment {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
  }

  .site-footer__links a {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .site-footer__payment {
    justify-content: end;
  }

  .site-footer__payment svg {
    width: 2.2rem;
  }

  @media (max-width: 820px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }

    .site-footer__payment {
      justify-content: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "Lash Candii"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Soft-glam lashes with a couture finish."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
