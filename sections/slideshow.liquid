<section class="slideshow full-width" aria-label="{{ section.settings.heading | escape }}">
  <div class="slideshow__track">
    {% for block in section.blocks %}
      <article class="slideshow__slide" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          {% liquid
            assign slide_focal = ''
            if block.settings.image.presentation.focal_point
              assign slide_focal = 'object-position: ' | append: block.settings.image.presentation.focal_point | append: ';'
            endif
          %}
          {{
            block.settings.image
            | image_url: width: 2200
            | image_tag:
              class: 'slideshow__image',
              widths: '750, 1100, 1500, 2200',
              sizes: '100vw',
              loading: 'lazy',
              style: slide_focal,
              alt: block.settings.heading
          }}
        {% else %}
          <span class="slideshow__placeholder"></span>
        {% endif %}
        <div class="slideshow__content">
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.copy }}</p>
          {% if block.settings.link_label != blank %}
            <a class="button" href="{{ block.settings.link | default: routes.all_products_collection_url }}">{{ block.settings.link_label }}</a>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .slideshow {
    background: #080607;
    color: #ffffff;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
  }

  .slideshow__track {
    display: grid;
    grid-auto-columns: 100%;
    grid-auto-flow: column;
  }

  .slideshow__slide {
    display: grid;
    min-height: clamp(28rem, 64svh, 42rem);
    scroll-snap-align: start;
  }

  .slideshow__image,
  .slideshow__placeholder,
  .slideshow__content {
    grid-area: 1 / 1;
  }

  .slideshow__image,
  .slideshow__placeholder {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .slideshow__placeholder {
    background:
      linear-gradient(90deg, rgba(8, 6, 7, 0.94), rgba(8, 6, 7, 0.28)),
      var(--color-accent-soft);
  }

  .slideshow__content {
    align-content: center;
    background: linear-gradient(90deg, rgba(8, 6, 7, 0.88), rgba(8, 6, 7, 0.18));
    display: grid;
    gap: 1rem;
    max-width: 42rem;
    padding: 4rem var(--page-margin);
  }

  .slideshow__content h2 {
    font-size: clamp(2.5rem, 6vw, 6rem);
    text-transform: uppercase;
  }

  .slideshow__content p:not(.eyebrow) {
    color: color-mix(in srgb, #ffffff 78%, transparent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lash Candii"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Accessible label",
      "default": "Featured lash stories"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "New lash drop"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Polished lash styles for lifted, camera-ready softness."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop the edit"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
