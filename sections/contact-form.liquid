<section class="contact-page">
  <div class="contact-page__header">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.copy }}</p>
  </div>

  {% form 'contact', class: 'contact-page__form' %}
    {% if form.posted_successfully? %}
      <p class="contact-page__success">{{ section.settings.success_message }}</p>
    {% endif %}

    {{ form.errors | default_errors }}

    <div class="contact-page__fields">
      <label>
        <span>Name</span>
        <input type="text" name="contact[name]" autocomplete="name" required>
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="contact[email]" autocomplete="email" required>
      </label>
      <label>
        <span>Topic</span>
        <select name="contact[topic]">
          <option>Order support</option>
          <option>Wholesale</option>
          <option>Press</option>
          <option>Product question</option>
        </select>
      </label>
      <label>
        <span>Message</span>
        <textarea name="contact[body]" rows="7" required></textarea>
      </label>
    </div>

    <button type="submit">{{ section.settings.button_label }}</button>
  {% endform %}
</section>

{% stylesheet %}
  .contact-page {
    align-items: start;
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: minmax(0, 0.8fr) minmax(20rem, 1fr);
    padding-block: 3rem 4rem;
  }

  .contact-page__header {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    position: sticky;
    top: 7rem;
  }

  .contact-page h1 {
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .contact-page__header p:not(.eyebrow),
  .contact-page__success {
    color: var(--color-muted);
    margin-top: 1rem;
  }

  .contact-page__form,
  .contact-page__fields {
    display: grid;
    gap: 1rem;
  }

  .contact-page__fields label {
    display: grid;
    gap: 0.45rem;
  }

  .contact-page__fields span {
    font-family: var(--font-secondary--family);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .contact-page {
      grid-template-columns: 1fr;
    }

    .contact-page__header {
      position: static;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Concierge"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How can we help?"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "For order support, press, wholesale, or lash recommendations, send a note and the team will reply soon."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you. Your message has been received."
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
