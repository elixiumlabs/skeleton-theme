{% comment %}
  This section is used in the blog template to render the blog page listing all
  articles within a blog.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

<section class="blog-page">
  <div class="blog-page__header">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ blog.title }}</h1>
  </div>

  <div class="blog-page__grid">
    {% paginate blog.articles by 6 %}
      {% for article in blog.articles %}
        <article class="blog-card">
          {% if article.image %}
            {{
              article.image
              | image_url: width: 900, height: 620, crop: 'center'
              | image_tag: class: 'blog-card__image', loading: 'lazy', alt: article.title
            }}
          {% endif %}
          <div class="blog-card__content">
            <h2>
              {{ article.title | link_to: article.url }}
            </h2>
            {% assign date = article.published_at | time_tag: format: 'date' %}
            <p>{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
            <p>{{ article.excerpt | strip_html | truncatewords: 28 }}</p>
          </div>
        </article>
      {% endfor %}

      {%- if paginate.pages > 1 -%}
        {{- paginate | default_pagination -}}
      {%- endif -%}
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .blog-page {
    padding-block: 3rem 4rem;
  }

  .blog-page__header {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    padding-bottom: 2rem;
  }

  .blog-page h1 {
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .blog-page__grid {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .blog-card {
    border: 1px solid var(--color-border);
    display: grid;
  }

  .blog-card__image {
    aspect-ratio: 16 / 11;
    object-fit: cover;
    width: 100%;
  }

  .blog-card__content {
    display: grid;
    gap: 0.8rem;
    padding: 1.25rem;
  }

  .blog-card h2 {
    font-size: clamp(1.45rem, 3vw, 2.4rem);
  }

  .blog-card h2 a {
    text-decoration: none;
  }

  .blog-card p {
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .blog-page__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Beauty notes"
    }
  ]
}
{% endschema %}
