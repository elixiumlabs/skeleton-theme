    },
    {
      "type": "text",
      "id": "ritual_step_3",
      "label": "Step 3",
      "default": "Lift, blend, and store the lash back in its tray."
    }
  ],
  "presets": [
    {
      "name": "Luxury lash homepage",
      "category": "Image"
    }
  ]
}
