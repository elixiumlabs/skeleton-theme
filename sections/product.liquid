{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign is_preorder = false

  if product.tags contains 'pre-order' or product.tags contains 'preorder'
    assign is_preorder = true
  endif
%}

<section class="product-detail">
  <div class="product-detail__media" data-media-gallery>
    {% if product.media.size > 0 %}
      {% for media in product.media %}
        {% if media.media_type == 'image' %}
          {% assign media_image = media.preview_image %}
          {% assign media_id = 'ProductMedia-' | append: media.id %}
          {{
            media_image
            | image_url: width: 1200
            | image_tag:
              class: 'product-detail__image',
              id: media_id,
              widths: '480, 760, 960, 1200',
              sizes: '(min-width: 990px) 52vw, 100vw',
              loading: 'lazy',
              alt: media.alt | default: product.title
          }}
        {% elsif media.media_type == 'video' %}
          {{ media | video_tag: controls: true, image_size: '1200x', class: 'product-detail__video' }}
        {% elsif media.media_type == 'external_video' %}
          {{ media | external_video_tag: class: 'product-detail__video' }}
        {% elsif media.media_type == 'model' %}
          {{ media | model_viewer_tag: class: 'product-detail__model', reveal: 'interaction', toggleable: true }}
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="product-detail__placeholder" aria-hidden="true"></div>
    {% endif %}

    <p class="product-detail__zoom-note">{{ section.settings.zoom_note }}</p>
  </div>

  <div class="product-detail__info">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ product.title }}</h1>
    <p class="product-detail__price price">
      {% if current_variant.compare_at_price > current_variant.price %}
        <span class="price__sale">{{ current_variant.price | money }}</span>
        <s>{{ current_variant.compare_at_price | money }}</s>
      {% else %}
        {{ current_variant.price | money }}
      {% endif %}
    </p>
    {% render 'unit-price', variant: current_variant %}
    <shopify-payment-terms variant-id="{{ current_variant.id }}"></shopify-payment-terms>
    <p class="product-detail__stock">
      {% if product.available %}
        {% if current_variant.inventory_management and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 8 %}
          Only {{ current_variant.inventory_quantity }} left
        {% elsif is_preorder %}
          Pre-order open for the next drop
        {% else %}
          In stock and ready to ship
        {% endif %}
      {% else %}
        Sold out
      {% endif %}
    </p>

    {% if product.description != blank %}
      <div class="product-detail__description">
        {{ product.description }}
      </div>
    {% endif %}

    <div class="product-detail__badges">
      <span>{{ section.settings.badge_1 }}</span>
      <span>{{ section.settings.badge_2 }}</span>
      <span>{{ section.settings.badge_3 }}</span>
    </div>

    <div class="product-detail__form">
      {% form 'product', product %}
        <label for="ProductSelect-{{ section.id }}">Style</label>
        <select id="ProductSelect-{{ section.id }}" name="id">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              data-media-id="{{ variant.featured_media.id }}"
              {% if variant == current_variant %}
                selected="selected"
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>

        {% for option in product.options_with_values %}
          {% assign option_name = option.name | downcase %}
          {% if option_name contains 'color' or option_name contains 'shade' or option_name contains 'finish' %}
            <div class="product-detail__swatches" aria-label="{{ option.name }}">
              {% for value in option.values %}
                <span title="{{ value | escape }}" style="background-color: {{ value | escape }};"></span>
              {% endfor %}
            </div>
          {% endif %}
        {% endfor %}

        <label for="Quantity-{{ section.id }}">Quantity</label>
        <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">

        {% if product.selling_plan_groups.size > 0 %}
          <fieldset class="product-detail__selling-plans">
            <legend>Purchase options</legend>
            <label>
              <input type="radio" name="selling_plan" value="" checked>
              <span>One-time purchase</span>
            </label>
            {% for allocation in current_variant.selling_plan_allocations %}
              <label>
                <input type="radio" name="selling_plan" value="{{ allocation.selling_plan.id }}">
                <span>{{ allocation.selling_plan.name }}</span>
              </label>
            {% endfor %}
          </fieldset>
        {% endif %}

        <input
          type="submit"
          value="{% if product.available %}{% if is_preorder %}Pre-order{% else %}Add to cart{% endif %}{% else %}Sold out{% endif %}"
          {% unless product.available %}
            disabled
          {% endunless %}
        >
        {{ form | payment_button }}
      {% endform %}
    </div>

    {% if current_variant.store_availabilities.size > 0 %}
      <div class="product-detail__pickup">
        <p class="eyebrow">In-store pickup</p>
        {% for availability in current_variant.store_availabilities limit: 3 %}
          <p>
            <strong>{{ availability.location.name }}</strong>
            {% if availability.available %}
              <span>Available, {{ availability.pick_up_time }}</span>
            {% else %}
              <span>Unavailable</span>
            {% endif %}
          </p>
        {% endfor %}
      </div>
    {% endif %}

    {% unless product.available %}
      <div class="product-detail__restock" id="BackInStock">
        <p class="eyebrow">{{ section.settings.restock_eyebrow }}</p>
        <h2>{{ section.settings.restock_heading }}</h2>
        {% form 'contact' %}
          <input type="hidden" name="contact[tags]" value="back-in-stock,{{ product.handle }}">
          <input type="hidden" name="contact[body]" value="Back in stock request for {{ product.title | escape }}">
          <label for="RestockEmail-{{ section.id }}" class="visually-hidden">Email</label>
          <input id="RestockEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" required>
          <button type="submit">Alert me</button>
        {% endform %}
      </div>
    {% endunless %}

    <div class="product-detail__accordions">
      <details open>
        <summary>Ingredients</summary>
        <div>
          {% if product.metafields.custom.ingredients != blank %}
            {{ product.metafields.custom.ingredients | metafield_tag }}
          {% else %}
            {{ section.settings.ingredients }}
          {% endif %}
        </div>
      </details>
      <details>
        <summary>Usage</summary>
        <div>
          {% if product.metafields.custom.usage != blank %}
            {{ product.metafields.custom.usage | metafield_tag }}
          {% else %}
            {{ section.settings.usage }}
          {% endif %}
        </div>
      </details>
      <details>
        <summary>Size chart</summary>
        <div>
          {% if product.metafields.custom.size_chart != blank %}
            {{ product.metafields.custom.size_chart | metafield_tag }}
          {% else %}
            {{ section.settings.size_chart }}
          {% endif %}
        </div>
      </details>
      <details>
        <summary>Shipping and delivery</summary>
        <div>
          {% if product.metafields.custom.shipping != blank %}
            {{ product.metafields.custom.shipping | metafield_tag }}
          {% else %}
            {{ section.settings.shipping }}
          {% endif %}
        </div>
      </details>
    </div>

    <div class="product-detail__app-blocks">
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

<script>
  (() => {
    const selector = document.getElementById('ProductSelect-{{ section.id }}');
    const terms = document.querySelector('shopify-payment-terms');
    if (!selector) return;

    selector.addEventListener('change', () => {
      const selected = selector.options[selector.selectedIndex];
      if (terms) terms.setAttribute('variant-id', selector.value);
      if (!selected.dataset.mediaId) return;
      const media = document.getElementById(`ProductMedia-${selected.dataset.mediaId}`);
      if (media) media.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  })();
</script>

{% stylesheet %}
  .product-detail {
    align-items: start;
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: minmax(0, 1.1fr) minmax(22rem, 0.9fr);
    padding-block: 3rem 4rem;
  }

  .product-detail__media {
    display: grid;
    gap: 1rem;
  }

  .product-detail__image,
  .product-detail__placeholder,
  .product-detail__video,
  .product-detail__model {
    aspect-ratio: 4 / 5;
    background: var(--color-accent-soft);
    height: auto;
    object-fit: cover;
    transition: transform 260ms ease;
    width: 100%;
  }

  .product-detail__image:hover {
    cursor: zoom-in;
    transform: scale(1.025);
  }

  .product-detail__zoom-note {
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  .product-detail__placeholder {
    background:
      radial-gradient(ellipse at 50% 52%, transparent 0 7rem, rgba(8, 6, 7, 0.9) 7.05rem 7.18rem, transparent 7.25rem),
      linear-gradient(145deg, rgba(244, 182, 200, 0.56), rgba(255, 255, 255, 0.94));
  }

  .product-detail__info {
    border-block: 1px solid var(--color-border);
    padding-block: 2rem;
    position: sticky;
    top: 1rem;
  }

  .product-detail h1 {
    font-size: clamp(2.35rem, 5vw, 5.25rem);
    margin-top: 0.75rem;
    text-transform: uppercase;
  }

  .product-detail__price {
    color: var(--color-accent);
    font-size: 1.4rem;
    margin-top: 1rem;
  }

  .product-detail__stock {
    color: var(--color-muted);
    font-family: var(--font-secondary--family);
    font-size: 0.88rem;
    font-weight: 700;
    margin-top: 0.45rem;
    text-transform: uppercase;
  }

  .product-detail__description {
    color: var(--color-muted);
    margin-top: 1.5rem;
  }

  .product-detail__description > * + * {
    margin-top: 0.9rem;
  }

  .product-detail__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.6rem;
  }

  .product-detail__badges span {
    background: var(--color-accent-soft);
    font-family: var(--font-secondary--family);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.48rem 0.65rem;
    text-transform: uppercase;
  }

  .product-detail__form {
    margin-top: 2rem;
  }

  .product-detail__form form {
    display: grid;
    gap: 0.75rem;
  }

  .product-detail__form label {
    font-family: var(--font-secondary--family);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .product-detail__form .shopify-payment-button {
    margin-top: 0.25rem;
  }

  .product-detail__form .shopify-payment-button__button {
    border-radius: 2px;
    min-height: 3rem;
  }

  .product-detail__selling-plans {
    border: 1px solid var(--color-border);
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
  }

  .product-detail__selling-plans legend {
    font-family: var(--font-secondary--family);
    font-size: 0.78rem;
    font-weight: 700;
    padding-inline: 0.25rem;
    text-transform: uppercase;
  }

  .product-detail__selling-plans label {
    align-items: center;
    display: flex;
    gap: 0.55rem;
    text-transform: none;
  }

  .product-detail__swatches {
    display: flex;
    gap: 0.45rem;
    margin-block: 0.2rem 0.4rem;
  }

  .product-detail__swatches span {
    background: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    height: 1.2rem;
    width: 1.2rem;
  }

  .product-detail__pickup,
  .product-detail__restock,
  .product-detail__accordions {
    border-top: 1px solid var(--color-border);
    margin-top: 1.5rem;
    padding-top: 1.5rem;
  }

  .product-detail__pickup p:not(.eyebrow) {
    display: grid;
    gap: 0.15rem;
    margin-top: 0.65rem;
  }

  .product-detail__pickup span,
  .product-detail__accordions div,
  .product-detail__restock h2 {
    color: var(--color-muted);
  }

  .product-detail__restock h2 {
    font-size: 1.2rem;
    margin-block: 0.35rem 1rem;
    text-transform: uppercase;
  }

  .product-detail__restock form {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .product-detail__accordions details {
    border-bottom: 1px solid var(--color-border);
    padding-block: 1rem;
  }

  .product-detail__accordions summary {
    cursor: pointer;
    font-family: var(--font-secondary--family);
    font-weight: 700;
    list-style: none;
    text-transform: uppercase;
  }

  .product-detail__accordions summary::-webkit-details-marker {
    display: none;
  }

  .product-detail__accordions div {
    margin-top: 0.75rem;
  }

  @media (max-width: 900px) {
    .product-detail {
      grid-template-columns: 1fr;
    }

    .product-detail__info {
      position: static;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lash wardrobe"
    },
    {
      "type": "text",
      "id": "zoom_note",
      "label": "Zoom note",
      "default": "Hover imagery to inspect curl, fiber texture, and band finish."
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "Featherlight band"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Reusable wear"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "Soft glam finish"
    },
    {
      "type": "text",
      "id": "restock_eyebrow",
      "label": "Restock eyebrow",
      "default": "Back-in-stock alert"
    },
    {
      "type": "text",
      "id": "restock_heading",
      "label": "Restock heading",
      "default": "Be first to know when this lash returns."
    },
    {
      "type": "richtext",
      "id": "ingredients",
      "label": "Ingredients fallback",
      "default": "<p>Synthetic fibers, cotton band, latex-free adhesive sold separately.</p>"
    },
    {
      "type": "richtext",
      "id": "usage",
      "label": "Usage fallback",
      "default": "<p>Trim from the outer corner, apply a thin adhesive layer, wait until tacky, then press along the lash line.</p>"
    },
    {
      "type": "richtext",
      "id": "size_chart",
      "label": "Size chart fallback",
      "default": "<p>Band length: 32 mm. Trim to fit your eye shape before first wear.</p>"
    },
    {
      "type": "richtext",
      "id": "shipping",
      "label": "Shipping fallback",
      "default": "<p>Orders ship in 1-3 business days. Delivery rates and timing are confirmed at checkout.</p>"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
