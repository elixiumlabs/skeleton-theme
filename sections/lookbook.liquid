<section class="lookbook full-width">
  <div class="lookbook__header">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
  </div>

  <div class="lookbook__grid">
    {% for block in section.blocks %}
      <article class="lookbook__item" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          {{
            block.settings.image
            | image_url: width: 1200
            | image_tag:
              class: 'lookbook__image',
              widths: '480, 760, 1000, 1200',
              sizes: '(min-width: 990px) 33vw, 100vw',
              loading: 'lazy',
              alt: block.settings.heading
          }}
        {% else %}
          <span class="lookbook__placeholder"></span>
        {% endif %}
        <div>
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.copy }}</p>
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .lookbook {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding-block: 3rem 4rem;
  }

  .lookbook > * {
    grid-column: 2;
  }

  .lookbook__header {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    padding-bottom: 2rem;
  }

  .lookbook h1 {
    font-size: clamp(2.6rem, 6vw, 6rem);
    margin-top: 0.7rem;
    text-transform: uppercase;
  }

  .lookbook__grid {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .lookbook__item {
    border: 1px solid var(--color-border);
    display: grid;
  }

  .lookbook__image,
  .lookbook__placeholder {
    aspect-ratio: 4 / 5;
    background: var(--color-accent-soft);
    object-fit: cover;
    width: 100%;
  }

  .lookbook__item div {
    padding: 1rem;
  }

  .lookbook__item h2 {
    font-size: 1.25rem;
    text-transform: uppercase;
  }

  .lookbook__item p {
    color: var(--color-muted);
    margin-top: 0.45rem;
  }

  @media (max-width: 900px) {
    .lookbook__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lookbook",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lookbook"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lash moods"
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Soft glam"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "A lifted, polished finish for everyday luxury."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        {
          "type": "look"
        },
        {
          "type": "look"
        },
        {
          "type": "look"
        }
      ]
    }
  ]
}
{% endschema %}
